#!name=WPS Office 每日签到
#!desc=WPS 每日签到和福利中心任务。Cookie 抓取可在插件参数里单独开关。
#!author=MaYIHEI; mirrored by cth123456
#!homepage=https://github.com/cth123456/script-library/tree/main/userscripts/wps
#!icon=https://raw.githubusercontent.com/MaYIHEI/pin/refs/heads/main/app/wps.png
#!tag=签到,WPS
#!system=iOS,iPadOS,macOS
#!loon_version=3.2.1(733)

[Argument]
cookie_capture = switch,true,tag=Cookie 抓取,desc=开启后访问 WPS 活动页会刷新 wps_sid，抓取成功后可关闭

[MITM]
hostname = personal-act.wps.cn

[Script]
http-request ^https:\/\/personal-act\.wps\.cn\/activity-rubik\/activity\/page_info tag=WPS Cookie, script-path=https://raw.githubusercontent.com/cth123456/script-library/main/userscripts/wps/wps.cookie.js, requires-body=false, img-url=https://raw.githubusercontent.com/MaYIHEI/pin/refs/heads/main/app/wps.png, enable={cookie_capture}

cron "0 10 * * *" script-path=https://raw.githubusercontent.com/cth123456/script-library/main/userscripts/wps/wps.js, tag=WPS签到, img-url=https://raw.githubusercontent.com/MaYIHEI/pin/refs/heads/main/app/wps.png, timeout=120, enable=true
